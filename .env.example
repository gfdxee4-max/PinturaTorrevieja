# Required on the production host. Keep every value server-side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REVIEWS_IP_SALT=

# Required only when the private moderation page is enabled.
REVIEWS_ADMIN_USER=
REVIEWS_ADMIN_PASSWORD=

# Local development/preview only. Never set this on Vercel.
REVIEWS_STORAGE=local
